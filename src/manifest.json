{
  "manifest_version": 3,
  "name": "Booth Product Edit Page ProTool",
  "version": "1.4.0",
  "description": "BOOTH商品編集画面の入力欄を使いやすく調整＋バリエーション価格一括変更＋並び替え",
  "permissions": ["activeTab", "scripting", "debugger", "storage"],
  "host_permissions": [
    "https://manage.booth.pm/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://manage.booth.pm/items/*/edit"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}